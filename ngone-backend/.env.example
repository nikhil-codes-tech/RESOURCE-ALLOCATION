# ── App ──────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
API_PREFIX=/api

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql://ngone:password@localhost:5432/ngone_db
DATABASE_URL_TEST=postgresql://ngone:password@localhost:5432/ngone_test

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────
ACCESS_TOKEN_SECRET=your_super_secret_64_char_access_key_here_change_this
REFRESH_TOKEN_SECRET=your_super_secret_64_char_refresh_key_here_change_this
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
RESET_TOKEN_EXPIRES=1h

# ── Google OAuth ─────────────────────────────────
# Get from: https://console.cloud.google.com
# Steps: Create Project → Enable People API → OAuth Consent Screen → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Microsoft OAuth ──────────────────────────────
# Get from: https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=your_microsoft_app_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_CALLBACK_URL=http://localhost:5000/api/auth/microsoft/callback
MICROSOFT_TENANT_ID=common

# ── AWS SES (Email) ──────────────────────────────
# Steps:
# 1. Go to https://console.aws.amazon.com → SES
# 2. Change region to ap-south-1 (Mumbai)
# 3. Verify your email/domain in "Verified identities"
# 4. Go to IAM → Create user "ngone-ses-user" with AmazonSESFullAccess
# 5. Create Access Key → copy below
# 6. Request production access to remove sandbox limits
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
EMAIL_FROM=hello@ngone.in
EMAIL_FROM_NAME=NGone Platform

# ── MSG91 (Indian SMS / OTP) ─────────────────────
# Get from: https://msg91.com → API → Auth Key
# Create OTP template, copy template ID
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_OTP_TEMPLATE_ID=your_otp_template_id
MSG91_SENDER_ID=NGONE

# ── Twilio (SMS fallback) ────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1234567890

# ── Cloudinary (File uploads) ────────────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=ngone

# ── Razorpay (Payments) ──────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── DARPAN API ───────────────────────────────────
DARPAN_API_URL=https://ngodarpan.gov.in/api/v1
DARPAN_API_KEY=your_darpan_api_key

# ── Feature flags ────────────────────────────────
ENABLE_SMS=true
ENABLE_EMAIL=true
ENABLE_PAYMENTS=true
ENABLE_SOCKET=true
