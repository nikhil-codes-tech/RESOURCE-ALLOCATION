# ── NG😊NE Backend — Production Environment Template ─────
# Copy this to Railway Dashboard → Service → Variables tab

# ── App ──────────────────────────────────────────
NODE_ENV=production
PORT=5000
CLIENT_URL=https://ngone.in
API_PREFIX=/api

# ── Database (Auto-set by Railway PostgreSQL addon) ──
# DATABASE_URL=postgresql://...railway.app/railway

# ── Redis (Auto-set by Railway Redis addon) ──────
# REDIS_URL=redis://...railway.app:6379

# ── JWT (IMPORTANT: generate unique secrets!) ─────
# Run: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
ACCESS_TOKEN_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
REFRESH_TOKEN_SECRET=CHANGE_ME_generate_different_with_openssl_rand_base64_64
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
RESET_TOKEN_EXPIRES=1h

# ── Google OAuth ─────────────────────────────────
GOOGLE_CLIENT_ID=1015443459371-9cn52fgbl4m6rap0vb5mesftsu3lho64.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://ngone-api.up.railway.app/api/auth/google/callback

# ── Microsoft OAuth (optional) ───────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=https://ngone-api.up.railway.app/api/auth/microsoft/callback
MICROSOFT_TENANT_ID=common

# ── AWS SES (optional — email sending) ───────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EMAIL_FROM=hello@ngone.in
EMAIL_FROM_NAME=NGone Platform

# ── MSG91 (optional — Indian SMS) ────────────────
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=NGONE

# ── Twilio (optional — SMS fallback) ─────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# ── Cloudinary (optional — image uploads) ────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=ngone_production

# ── Razorpay (optional — payments) ───────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── DARPAN (optional — NGO verification) ─────────
DARPAN_API_URL=https://ngodarpan.gov.in/api/v1
DARPAN_API_KEY=

# ── Feature Flags ────────────────────────────────
ENABLE_SMS=false
ENABLE_EMAIL=false
ENABLE_PAYMENTS=false
ENABLE_SOCKET=true
